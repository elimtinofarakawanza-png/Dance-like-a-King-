body {
  background: black;
  color: white;
  font-family: monospace;
}

#game {
  width: 300px;
  height: 500px;
  margin: auto;
  border: 2px solid white;
  position: relative;
  overflow: hidden;
}

.arrow {
  width: 40px;
  height: 40px;
  position: absolute;
  left: 130px;
  background: red;
}

#hit-zone {
  width: 100%;
  height: 10px;
  background: white;
  position: absolute;
  bottom: 50px;
}
